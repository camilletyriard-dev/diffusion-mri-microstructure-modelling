    issue: 3
    start: 2241
    end: 2254
  - type: article
    authors:
      - family-names: Ferizi
        given-names: U.
    title: "A ranking of diffusion MRI compartment models with in vivo human brain data"
    journal: "Magnetic Resonance in Medicine"
    year: 2014
